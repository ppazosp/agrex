{
  "name": "@ppazosp/agrex",
  "version": "0.3.2",
  "description": "Real-time graph visualizer for AI agent execution flows",
  "keywords": [
    "agent",
    "graph",
    "visualizer",
    "react",
    "ai",
    "llm",
    "react-flow"
  ],
  "author": "ppazosp",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ppazosp/agrex.git"
  },
  "homepage": "https://github.com/ppazosp/agrex",
  "bugs": {
    "url": "https://github.com/ppazosp/agrex/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./mocks": {
      "import": {
        "types": "./dist/mocks/index.d.ts",
        "default": "./dist/mocks/index.js"
      },
      "require": {
        "types": "./dist/mocks/index.d.cts",
        "default": "./dist/mocks/index.cjs"
      }
    },
    "./layout/force": {
      "import": {
        "types": "./dist/layout/force.d.ts",
        "default": "./dist/layout/force.js"
      },
      "require": {
        "types": "./dist/layout/force.d.cts",
        "default": "./dist/layout/force.cjs"
      }
    },
    "./layout/dagre": {
      "import": {
        "types": "./dist/layout/dagre.d.ts",
        "default": "./dist/layout/dagre.js"
      },
      "require": {
        "types": "./dist/layout/dagre.d.cts",
        "default": "./dist/layout/dagre.cjs"
      }
    },
    "./styles.css": "./dist/index.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "tsup"
  },
  "peerDependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@xyflow/react": ">=12",
    "d3-force": "^3.0.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "d3-force": {
      "optional": true
    },
    "@dagrejs/dagre": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/d3-force": "^3.0.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^2.1.9",
    "@xyflow/react": "^12.6.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
