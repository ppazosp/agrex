{
  "name": "agrex-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter playground dev",
    "build": "pnpm --filter agrex build",
    "test": "pnpm --filter agrex test",
    "lint": "tsc --noEmit",
    "lint:eslint": "eslint packages/agrex/src/",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\" \"packages/*/*.{json,ts,md}\" \"*.{js,json,md}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx}\" \"packages/*/*.{json,ts,md}\" \"*.{js,json,md}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
