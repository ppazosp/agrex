{
  "name": "agrex",
  "version": "0.1.0",
  "description": "Real-time graph visualizer for AI agent execution flows",
  "keywords": ["agent", "graph", "visualizer", "react", "ai", "llm", "react-flow"],
  "author": "ppazosp",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ppazosp/agrex.git"
  },
  "homepage": "https://github.com/ppazosp/agrex",
  "bugs": {
    "url": "https://github.com/ppazosp/agrex/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./mocks": {
      "import": "./dist/mocks/index.js",
      "types": "./dist/mocks/index.d.ts"
    },
    "./layout/force": {
      "import": "./dist/layout/force.js",
      "types": "./dist/layout/force.d.ts"
    },
    "./layout/dagre": {
      "import": "./dist/layout/dagre.js",
      "types": "./dist/layout/dagre.d.ts"
    },
    "./layout/elk": {
      "import": "./dist/layout/elk.js",
      "types": "./dist/layout/elk.d.ts"
    },
    "./styles.css": "./dist/index.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "tsup"
  },
  "peerDependencies": {
    "@xyflow/react": ">=12",
    "react": ">=18",
    "react-dom": ">=18",
    "@dagrejs/dagre": "^3.0.0",
    "elkjs": "^0.11.1"
  },
  "peerDependenciesMeta": {
    "@dagrejs/dagre": { "optional": true },
    "elkjs": { "optional": true }
  },
  "dependencies": {
    "d3-force": "^3.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/d3-force": "^3.0.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@xyflow/react": "^12.6.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
